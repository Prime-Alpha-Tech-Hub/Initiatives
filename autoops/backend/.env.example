SECRET_KEY=autoops-dev-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=*
DATABASE_URL=sqlite:///autoops.sqlite3

# ── Task queue — required for scheduled automation ───────────────────────────
# Install Redis: https://redis.io/docs/getting-started/
# macOS: brew install redis && brew services start redis
# Ubuntu: sudo apt install redis-server && sudo systemctl start redis
REDIS_URL=redis://localhost:6379/0

# ── Email (Resend — free tier) ───────────────────────────────────────────────
RESEND_API_KEY=

# ── Sanctions screening (OpenSanctions — free tier available) ────────────────
# Get key at: https://www.opensanctions.org/api/
OPENSANCTIONS_API_KEY=

# ── Email inbox (IMAP — for email automation) ────────────────────────────────
# IMAP_HOST=imap.gmail.com
# IMAP_USER=your@email.com
# IMAP_PASSWORD=your-app-password

# ── AlphaCore integration ────────────────────────────────────────────────────
ALPHACORE_API_URL=http://localhost:8080/api
ALPHACORE_API_KEY=

# ── AWS DynamoDB ──────────────────────────────────────────────────────────────
# IAM role on EC2 handles auth automatically — no keys needed on EC2.
# For local dev, set these or use aws configure:
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
AWS_REGION=eu-west-2
TABLE_PREFIX=ao_   # change per app: dd_, ao_
# DYNAMODB_ENDPOINT=http://localhost:8000  # uncomment for DynamoDB Local
