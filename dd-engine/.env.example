SECRET_KEY=dd-engine-dev-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=*
DATABASE_URL=sqlite:///dd_engine.sqlite3

# ── Required for AI analysis ──────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Optional: link to AlphaCore (Initiative 01) ───────────────────────────────
ALPHACORE_API_URL=http://localhost:8080/api
ALPHACORE_API_KEY=

# ── AWS DynamoDB ──────────────────────────────────────────────────────────────
# IAM role on EC2 handles auth automatically — no keys needed on EC2.
# For local dev, set these or use aws configure:
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
AWS_REGION=eu-west-2
TABLE_PREFIX=dd_   # change per app: dd_, ao_
# DYNAMODB_ENDPOINT=http://localhost:8000  # uncomment for DynamoDB Local

# ── URL prefix ───────────────────────────────────────────────────────────────
# SCRIPT_NAME=/dd          # set this when running behind Nginx
ALPHACORE_API_URL=http://localhost:8080/alphacore/api

# ── Integration settings (leave blank for standalone mode) ──────────────────
INTEGRATION_API_KEY=
# ALPHACORE_URL already present above
AUTOOPS_URL=
AUTOOPS_API_KEY=
DD_ENGINE_URL=
