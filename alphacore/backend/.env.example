# AlphaCore — Environment Configuration
# Copy to .env and fill in your values

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-generate-with-python-secrets
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,localhost

# ── Database — swap freely ────────────────────────────────────────────────────
# SQLite (development — zero config):
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (recommended for production):
# DATABASE_URL=postgres://user:password@localhost:5432/alphacore

# MySQL:
# DATABASE_URL=mysql://user:password@localhost:3306/alphacore

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# ── Firm Identity (customise per client deployment) ───────────────────────────
FIRM_NAME=AlphaCore
FIRM_DOMAIN=alphacore.io

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Setup (5 min, free, External works fine):
#   1. console.cloud.google.com → New project
#   2. APIs & Services → OAuth consent screen → External → fill name + email
#   3. Credentials → Create → OAuth 2.0 Client ID → Web application
#   4. Authorized redirect URIs → add:
#        http://localhost:8080/api/auth/social/google/callback/   (dev)
#        https://yourdomain.com/api/auth/social/google/callback/  (prod)
#   5. Copy Client ID and Secret below
#   6. In Django admin → Sites → change example.com to localhost:8080
#   7. Social Applications → Add → Google → paste ID + Secret → assign site
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── AWS DynamoDB ──────────────────────────────────────────────────────────────
# IAM role on EC2 handles auth automatically — no keys needed on EC2.
# For local dev, set these or use aws configure:
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
AWS_REGION=eu-west-2
TABLE_PREFIX=alphacore_   # change per app: dd_, ao_
# DYNAMODB_ENDPOINT=http://localhost:8000  # uncomment for DynamoDB Local
